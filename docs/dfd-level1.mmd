    %% ---------- External entities ----------
    STU["Student"]
    APP["Applicant /<br/>Prospective Merchant"]
    MADM["Merchant Admin"]
    MSTF["Merchant Staff"]
    FIN["Finance / Admin"]
    SADM["Super Admin"]
    VIS["Visitor"]
    MAIL["Email / SMTP"]

    %% ---------- Processes ----------
    P1(["1.0 Authentication &<br/>Account Mgmt"])
    P2(["2.0 Wallet Top-up /<br/>Cash-in"])
    P3(["3.0 Payment / POS"])
    P4(["4.0 P2P Transfer"])
    P5(["5.0 Voucher Lifecycle"])
    P6(["6.0 Encashment"])
    P7(["7.0 Token Economy<br/>Control"])
    P8(["8.0 Stall Application &<br/>Onboarding"])
    P9(["9.0 Merchant Onboarding<br/>Pipeline"])
    P10(["10.0 Lease & Rent Mgmt"])
    P11(["11.0 Inventory &<br/>Restricted Products"])
    P12(["12.0 Reporting &<br/>Dashboards"])

    %% ---------- Data stores ----------
    D1[("D1 role")]
    D2[("D2 users")]
    D3[("D3 course")]
    D4[("D4 student_info")]
    D5[("D5 student_wallets")]
    D6[("D6 merchant_wallets")]
    D7[("D7 stalls")]
    D8[("D8 merchant")]
    D9[("D9 stall_applications")]
    D10[("D10 merchant_applications")]
    D11[("D11 app_product_types")]
    D12[("D12 merchant_accounts")]
    D13[("D13 merchant_leases")]
    D14[("D14 rent_payments")]
    D15[("D15 restricted_products")]
    D16[("D16 merchant_inventory")]
    D17[("D17 qr_orders")]
    D18[("D18 qr_order_items")]
    D19[("D19 payment_verifications")]
    D20[("D20 qr_tokens")]
    D21[("D21 transactions")]
    D22[("D22 topup_requests")]
    D23[("D23 encashment_requests")]
    D24[("D24 p2p_transfers")]
    D25[("D25 vouchers")]
    D26[("D26 voucher_payment_log")]
    D27[("D27 school_revenue_ledger")]
    D28[("D28 system_settings")]
    D29[("D29 systemic_audit_trail")]

    %% ---------- 1.0 Auth ----------
    STU & MADM & MSTF & FIN & SADM -->|"credentials"| P1
    P1 -->|"verify user & role"| D2
    D1 -->|"role"| P1
    P1 -->|"profile lookup"| D4
    D3 -->|"course"| P1
    P1 -->|"issue/expire QR token"| D20
    P1 -->|"OTP, temp password"| MAIL
    P1 -->|"login/logout events"| D29
    P1 -->|"session, dashboard route"| STU

    %% ---------- 2.0 Top-up ----------
    STU -->|"top-up request"| P2
    FIN -->|"cash-in, approve/reject"| P2
    P2 -->|"store request"| D22
    P2 -->|"lock vault & fee rate"| D28
    P2 -->|"credit balance"| D5
    P2 -->|"net service fee"| D27
    P2 -->|"record cash_in txn"| D21
    P2 -->|"audit"| D29
    P2 -->|"receipt"| STU

    %% ---------- 3.0 Payment/POS ----------
    MADM -->|"create QR order"| P3
    MSTF -->|"POS order"| P3
    STU -->|"scan & pay"| P3
    P3 -->|"order + items"| D17
    P3 --> D18
    D16 -->|"price, stock"| P3
    D15 -->|"restricted check"| P3
    P3 -->|"debit student"| D5
    P3 -->|"credit merchant"| D6
    P3 -->|"record payment txn"| D21
    P3 -->|"audit"| D29
    P3 -->|"receipt / status"| STU

    %% ---------- 4.0 P2P ----------
    STU -->|"transfer details"| P4
    P4 -->|"debit / credit wallets"| D5
    P4 -->|"record transfer"| D24
    P4 -->|"record txn"| D21
    P4 -->|"audit"| D29
    P4 -->|"confirmation"| STU

    %% ---------- 5.0 Voucher ----------
    FIN -->|"issue voucher"| P5
    VIS -->|"voucher payment"| P5
    MSTF -->|"scan voucher"| P5
    P5 -->|"create / update voucher"| D25
    P5 -->|"log redemption"| D26
    P5 -->|"credit merchant"| D6
    P5 -->|"record voucher txn"| D21
    P5 -->|"audit"| D29
    P5 -->|"voucher / balance"| VIS

    %% ---------- 6.0 Encashment ----------
    MADM -->|"encashment request"| P6
    FIN -->|"release / reject"| P6
    P6 -->|"store request"| D23
    P6 -->|"debit merchant"| D6
    P6 -->|"record txn"| D21
    P6 -->|"audit"| D29
    P6 -->|"status"| MADM

    %% ---------- 7.0 Economy ----------
    SADM -->|"mint, cap increase, settings"| P7
    P7 -->|"update vault / cap / fees"| D28
    P7 -->|"record mint / cap txn"| D21
    P7 -->|"audit"| D29
    P7 -->|"economy status"| SADM

    %% ---------- 8.0 Stall onboarding ----------
    APP -->|"application, documents, payment proof"| P8
    FIN -->|"review, schedule, record down-payment"| P8
    P8 -->|"store application"| D9
    P8 -->|"lock / update stall"| D7
    P8 -->|"verify payment"| D19
    P8 -->|"create account"| D12
    P8 --> D2
    P8 -->|"temp password, meet-up notice"| MAIL
    P8 -->|"audit"| D29
    P8 -->|"status"| APP

    %% ---------- 9.0 Merchant pipeline ----------
    APP -->|"merchant application"| P9
    FIN -->|"compliance review"| P9
    SADM -->|"exec sign-off, approval"| P9
    P9 -->|"update stages"| D10
    P9 -->|"product types"| D11
    P9 -->|"generate user"| D2
    P9 -->|"email"| MAIL
    P9 -->|"audit"| D29

    %% ---------- 10.0 Lease & rent ----------
    FIN -->|"create lease"| P10
    MADM -->|"rent payment"| P10
    P10 -->|"lease record"| D13
    P10 -->|"payment record"| D14
    D7 -->|"stall"| P10
    D8 -->|"merchant"| P10
    P10 -->|"audit"| D29
    P10 -->|"lease status, receipt"| MADM

    %% ---------- 11.0 Inventory ----------
    MADM -->|"menu / inventory CRUD"| P11
    SADM -->|"manage restricted list"| P11
    P11 -->|"update inventory"| D16
    P11 -->|"update restricted list"| D15
    P11 -->|"audit"| D29
    P11 -->|"catalog"| MADM

    %% ---------- 12.0 Reporting ----------
    STU & MADM & FIN & SADM -->|"view request"| P12
    D21 -->|"transactions"| P12
    D5 --> P12
    D6 --> P12
    D27 --> P12
    D28 --> P12
    D29 -->|"audit log"| P12
    P12 -->|"dashboards, reports, exports"| FIN
