flowchart TD
    START(["Start"])
    LOGIN["Login / Authenticate"]
    ROLECHK{"Role?"}

    START --> NEWUSER{"New user?"}
    NEWUSER -->|"Yes — wants a stall"| APPLY
    NEWUSER -->|"No"| LOGIN
    LOGIN --> ROLECHK

    %% ================= STALL & MERCHANT ONBOARDING =================
    subgraph SO["Stall Application & Merchant Onboarding"]
        APPLY["Submit stall application<br/>(business info, documents)"]
        LOCKSTALL["Stall locked: pending_application<br/>(15-min hold)"]
        REVIEW{"Finance reviews<br/>application"}
        REJECT1["Rejected — notify applicant"]
        MEETUP["Schedule meet-up"]
        DOWNPAY["Record down payment<br/>+ verify GCash ref"]
        COMPLIANCE{"Compliance review"}
        REJECT2["Rejected — notify applicant"]
        EXEC{"Exec sign-off /<br/>Super Admin approval"}
        REJECT3["Rejected — notify applicant"]
        GENACC["Generate merchant account<br/>+ temp password"]
        EMAIL1["Email credentials<br/>to applicant"]
        STALLVACANT["Stall freed<br/>(status: vacant)"]

        APPLY --> LOCKSTALL --> REVIEW
        REVIEW -->|"Reject"| REJECT1
        REVIEW -->|"Approve"| MEETUP --> DOWNPAY --> COMPLIANCE
        COMPLIANCE -->|"Reject"| REJECT2
        COMPLIANCE -->|"Pass"| EXEC
        EXEC -->|"Reject"| REJECT3
        EXEC -->|"Approve"| GENACC --> EMAIL1
        LOCKSTALL -.->|"15 min expires,<br/>no submission"| STALLVACANT
        REJECT1 & REJECT2 & REJECT3 --> STALLVACANT
    end

    EMAIL1 --> LOGIN

    %% ================= ROLE BRANCHES =================
    ROLECHK -->|"Student"| STUDASH["Student Dashboard"]
    ROLECHK -->|"Merchant Admin/Staff"| MERCHDASH["Merchant Dashboard"]
    ROLECHK -->|"Finance/Admin"| FINDASH["Finance Dashboard"]
    ROLECHK -->|"Super Admin"| SADASH["Super Admin Dashboard"]

    %% ================= WALLET TOP-UP =================
    subgraph TU["Wallet Top-up"]
        TOPUPREQ["Student submits<br/>top-up request"]
        VAULTCHK{"Cashier verifies &<br/>checks vault balance"}
        TUREJECT["Reject request"]
        DEDUCTVAULT["Deduct from cashier vault"]
        APPLYFEE["Apply service fee →<br/>school revenue ledger"]
        CREDITWALLET["Credit student wallet"]
        LOGTXN1["Log transaction<br/>+ audit trail"]

        TOPUPREQ --> VAULTCHK
        VAULTCHK -->|"Insufficient vault"| TUREJECT
        VAULTCHK -->|"Approved"| DEDUCTVAULT --> APPLYFEE --> CREDITWALLET --> LOGTXN1
    end

    STUDASH --> TOPUPREQ
    FINDASH --> VAULTCHK

    %% ================= PAYMENT / POS =================
    subgraph PAY["Payment / POS"]
        ORDER["Merchant/Staff creates<br/>QR order or POS cart"]
        RESTRICT{"Item restricted?"}
        BLOCK["Block item from sale"]
        SCAN["Student scans QR & pays"]
        BALCHK{"Sufficient wallet<br/>balance?"}
        PAYFAIL["Payment declined"]
        DEBIT["Debit student wallet"]
        CREDITMERCH["Credit merchant wallet"]
        LOGTXN2["Log transaction<br/>+ audit trail"]

        ORDER --> RESTRICT
        RESTRICT -->|"Yes"| BLOCK
        RESTRICT -->|"No"| SCAN --> BALCHK
        BALCHK -->|"No"| PAYFAIL
        BALCHK -->|"Yes"| DEBIT --> CREDITMERCH --> LOGTXN2
    end

    MERCHDASH --> ORDER
    STUDASH --> SCAN

    %% ================= P2P TRANSFER =================
    subgraph P2P["Peer-to-Peer Transfer"]
        P2PREQ["Student initiates transfer<br/>to another student"]
        P2PCHK{"Sufficient balance?"}
        P2PFAIL["Transfer declined"]
        P2PMOVE["Debit sender / credit receiver"]
        LOGTXN3["Log transaction<br/>+ audit trail"]

        P2PREQ --> P2PCHK
        P2PCHK -->|"No"| P2PFAIL
        P2PCHK -->|"Yes"| P2PMOVE --> LOGTXN3
    end

    STUDASH --> P2PREQ

    %% ================= VOUCHER LIFECYCLE =================
    subgraph VOU["Voucher Lifecycle (Visitors)"]
        ISSUEV["Finance issues voucher<br/>(value + expiry)"]
        VISPAY["Visitor pays merchant<br/>using voucher"]
        VEXPCHK{"Voucher valid<br/>& has balance?"}
        VFAIL["Voucher rejected /<br/>expired"]
        VDEDUCT["Deduct from voucher balance"]
        VCREDIT["Credit merchant wallet"]
        LOGTXN4["Log redemption<br/>+ audit trail"]
        VEXPIRE["Voucher auto-expires<br/>unused balance forfeited"]

        ISSUEV --> VISPAY --> VEXPCHK
        VEXPCHK -->|"No"| VFAIL
        VEXPCHK -->|"Yes"| VDEDUCT --> VCREDIT --> LOGTXN4
        ISSUEV -.->|"expiry reached"| VEXPIRE
    end

    FINDASH --> ISSUEV

    %% ================= ENCASHMENT =================
    subgraph ENC["Merchant Encashment"]
        ENCREQ["Merchant requests<br/>encashment"]
        ENCCHK{"Finance reviews &<br/>approves"}
        ENCREJECT["Reject request"]
        ENCDEBIT["Debit merchant wallet"]
        ENCRELEASE["Release cash to merchant"]
        LOGTXN5["Log transaction<br/>+ audit trail"]

        ENCREQ --> ENCCHK
        ENCCHK -->|"Reject"| ENCREJECT
        ENCCHK -->|"Approve"| ENCDEBIT --> ENCRELEASE --> LOGTXN5
    end

    MERCHDASH --> ENCREQ
    FINDASH --> ENCCHK

    %% ================= TOKEN ECONOMY CONTROL =================
    subgraph ECO["Token Economy Control"]
        MINTREQ["Super Admin requests<br/>mint (vault replenishment)"]
        MINTCHK{"Within soft/hard<br/>monthly limit?"}
        MINTBLOCK["Mint blocked"]
        MINTPIN{"PIN required<br/>above soft limit"}
        MINTOK["Vault credited<br/>+ circulation updated"]
        CAPREQ["Super Admin raises<br/>circulation cap"]
        SETTINGS["Update fees / token rate /<br/>system settings"]
        LOGTXN6["Log transaction<br/>+ audit trail"]

        MINTREQ --> MINTCHK
        MINTCHK -->|"Exceeds hard limit"| MINTBLOCK
        MINTCHK -->|"Within limit"| MINTPIN
        MINTPIN -->|"Verified"| MINTOK --> LOGTXN6
        CAPREQ --> LOGTXN6
        SETTINGS --> LOGTXN6
    end

    SADASH --> MINTREQ
    SADASH --> CAPREQ
    SADASH --> SETTINGS

    %% ================= INVENTORY & RESTRICTED PRODUCTS =================
    subgraph INV["Inventory & Restricted Products"]
        ADDITEM["Merchant adds/edits<br/>inventory item"]
        FLAGCHK{"Matches restricted<br/>product list?"}
        AUTORESTRICT["Auto-flag as restricted"]
        AVAILABLE["Item available for sale"]

        ADDITEM --> FLAGCHK
        FLAGCHK -->|"Yes"| AUTORESTRICT
        FLAGCHK -->|"No"| AVAILABLE
    end

    MERCHDASH --> ADDITEM
    AUTORESTRICT --> RESTRICT
    AVAILABLE --> ORDER

    %% ================= REPORTING (terminal) =================
    LOGTXN1 & LOGTXN2 & LOGTXN3 & LOGTXN4 & LOGTXN5 & LOGTXN6 --> AUDIT["Systemic Audit Trail"]
    AUDIT --> REPORTS["Dashboards / Reports /<br/>Audit Log Viewer"]
    REPORTS --> END(["End"])
