flowchart TD
    STU["Student"]
    APP["Applicant /<br/>Prospective Merchant"]
    MADM["Merchant Admin"]
    MSTF["Merchant Staff"]
    FIN["Finance / Admin<br/>(Cashier)"]
    SADM["Super Admin"]
    VIS["Visitor"]
    MAIL["Email / SMTP<br/>Service"]

    SYS(["0&nbsp;&nbsp;GenPay System"])

    STU -->|"login, top-up request, QR payment, P2P transfer"| SYS
    SYS -->|"wallet balance, transaction history, OTP"| STU

    APP -->|"stall application, documents, down-payment proof"| SYS
    SYS -->|"application status, meet-up schedule"| APP

    MADM -->|"inventory & menu, QR/POS orders, encashment request, rent payment, staff mgmt"| SYS
    SYS -->|"order status, wallet balance, sales reports"| MADM

    MSTF -->|"POS orders, QR & voucher scans"| SYS
    SYS -->|"order confirmation, receipts"| MSTF

    FIN -->|"cash-in, top-up approval, encashment release, voucher issue, application review"| SYS
    SYS -->|"pending requests, balances, reports"| FIN

    SADM -->|"mint request, cap increase, system settings, restricted products"| SYS
    SYS -->|"economy status, audit log"| SADM

    VIS -->|"voucher payment"| SYS
    SYS -->|"voucher receipt, remaining balance"| VIS

    SYS -->|"OTP, temp passwords, onboarding & status emails"| MAIL
